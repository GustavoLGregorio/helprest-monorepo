                {
                    "name": "Content-Type",
                    "value": "application/json"
                }
            ],
            "body": {
                "mimeType": "application/json",
                "text": "{\n  \"name\": \"Teste User\",\n  \"email\": \"teste@email.com\",\n  \"password\": \"senha123\",\n  \"birthDate\": \"1995-06-15\"\n}"
            }
        },
        {
            "_id": "req_login",
            "_type": "request",
            "parentId": "fld_auth",
